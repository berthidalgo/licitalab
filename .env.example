# Supabase
# IMPORTANTE: Para ingesta (escritura) usa la SERVICE_ROLE key (no la anon key)
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://postgres:tu_password@db.tu-proyecto.supabase.co:5432/postgres

# OpenAI (opcional para embeddings iniciales)
OPENAI_API_KEY=sk-...

# Render / Production
ENV=development
DEBUG=true

# OCDS Ingestion (Día 2)
# Obtén la URL actualizada desde https://contratacionesabiertas.oece.gob.pe/descargas
OCDS_RELEASES_URL=https://contratacionesabiertas.oece.gob.pe/descargas/releases_2026.jsonl
